# ── frontend/.env.local.example ──────────────────────────────────────────────
# Template para desenvolvimento local (npm run dev).
# Copia para .env.local e preenche com os valores reais do teu projecto Supabase.
#
#   cp .env.local.example .env.local
#
# O .env.local é ignorado pelo git (nunca commitar).
# Para builds Docker, as variáveis vêm dos build.args no docker-compose.yml.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard: supabase.com/dashboard/project/<PROJECT_REF>/settings/api
VITE_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon_public_key>    # Settings → API → "anon public" (NÃO é a service_role)

# ── API Backend ──────────────────────────────────────────────────────────────
# Dev local (Vite em 5173 → proxy → backend em 8000):
VITE_API_URL=http://localhost:8000
# Produção via nginx (mesmo domínio, URLs relativas):
# VITE_API_URL=
